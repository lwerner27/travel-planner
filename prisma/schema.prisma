// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       String    @id
  email    String    @unique
  password String
  sessions Session[]
  trips    Trip[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(references: [id], fields: [userId], onDelete: Cascade)
}

model Trip {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(references: [id], fields: [userId], onDelete: Cascade)
  title       String
  startDate   DateTime
  endDate     DateTime
  coverImage  String?
  events      Event[]
  locations   Location[]
  attachments Attachment[]
}

model Event {
  id          String   @id @default(uuid())
  tripId      String
  date        String   // Format: YYYY-MM-DD
  title       String
  time        String?
  description String?
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Location {
  id          String   @id @default(uuid())
  tripId      String
  date        String   // Format: YYYY-MM-DD
  name        String
  address     String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Attachment {
  id          String   @id @default(uuid())
  tripId      String
  date        String   // Format: YYYY-MM-DD
  fileName    String
  fileUrl     String
  mimeType    String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
